# Configurações do Active Directory / LDAP
# Substitua pelos valores do seu ambiente AD

# Endereço do servidor LDAP (Domain Controller)
# Exemplos: 192.168.1.10, dc01.empresa.com.br, ldap://dc01.empresa.local
LDAP_SERVER=ldap://s02rec1.adt.com.br:389

# Domínio do Active Directory
# Exemplo: empresa.com.br, empresa.local
LDAP_DOMAIN=adt.com.br

# Base de pesquisa no AD (Distinguished Name da Organizational Unit)
# Exemplo: DC=empresa,DC=local ou OU=Usuarios,DC=empresa,DC=local
LDAP_SEARCH_BASE=DC=adt,DC=com,DC=br
# Chave secreta para sessões Flask (altere para um valor único em produção)
SECRET_KEY=Svp0rt3@